{
  ".": {
    "types": "./services.d.ts",
    "default": "./services.js"
  },
  "./vscode/*.css": {
    "default": "./vscode/src/*.css"
  },
  "./vscode/*": {
    "types": "./vscode/src/*.d.ts",
    "default": "./vscode/src/*.js"
  },
  "./*": {
    "types": "./*.d.ts",
    "default": "./*.js"
  }
}